# Vapi API Key (https://vapi.ai)
VAPI_API_KEY=your_vapi_api_key_here

# Vonage SMS (https://dashboard.nexmo.com)
VONAGE_API_KEY=your_vonage_api_key_here
VONAGE_API_SECRET=your_vonage_api_secret_here
VONAGE_FROM_NUMBER=+46700000000

# Supabase (KDS / Lovable Dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
# Multi-tenancy: UUID från public.restaurants (id för din restaurang). Sätts efter Fas C migration.
# RESTAURANT_UUID=

# Fas 1 Safety Net: admin-invalidate och circuit-breaker (loggar)
ADMIN_SECRET=your_admin_secret_here

# Valfritt men rekommenderat i produktion: samma värde i Railway + Vapi (Custom header eller Bearer).
# Tom = ingen auth på POST /place_order och /vapi/webhook (bakåtkompatibelt).
# WEBHOOK_SHARED_SECRET=generera_en_lång_slumpmässig_sträng

# Fas 2: Kryptering av tenant-nycklar i restaurant_secrets (Railway)
# ENCRYPTION_SECRET=minst_32_tecken_lång_hemlig_sträng

# Order integrity (Fas 1) – produktionsdefault
# Sätt till false ENDAST i lokal utveckling utan Supabase. I produktion måste denna vara true,
# annars kan ett Supabase-fel ge falsk ordersuccess till kunden.
ORDER_REQUIRE_DB_COMMIT=true
# Dashboard läser ordrar från Supabase som primär källa.
DASHBOARD_FROM_DB=true
# Default-tenant för lokal /dashboard?rest_id=...-länk om query saknas.
DEFAULT_DASHBOARD_REST_ID=Gislegrillen_01
# Tvinga AI att gå via /draft_order innan /place_order. Lämna false tills systemprompten är publicerad.
REQUIRE_DRAFT_TOKEN=false

# HMAC-secret för draft-tokens (confirmation.py). Behöver vara satt i prod – annars används ENCRYPTION_SECRET som fallback.
# DRAFT_SIGNING_SECRET=minst_32_tecken_lång_hemlig_sträng

# Operatörslarm: nummer som får SMS vid P0/P1-incidenter (kan även sättas i ops_settings i Supabase).
# OWNER_ALERT_PHONE=+46700000000
# Valfri webhook (Slack/Discord-format {"text": ...}) för larm.
# ALERT_WEBHOOK_URL=

# Krypteringsnyckel för nattliga backuper (scripts/backup_supabase.py).
# Generera: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Samma värde som GitHub secret BACKUP_ENCRYPTION_KEY. Förlora den INTE – utan den är backuperna oläsbara.
# BACKUP_ENCRYPTION_KEY=

# Server Configuration
HOST=0.0.0.0
PORT=8000
